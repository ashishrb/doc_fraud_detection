# Copy to .env and fill in. All keys are OPTIONAL for the POC — missing keys
# cause the corresponding agent/step to degrade gracefully (see SETUP.md).

# --- Azure Document Intelligence (Step 2 primary OCR) ---
# Obtain: Azure Portal -> create "Document Intelligence" resource -> Keys & Endpoint
AZURE_DOC_INTELLIGENCE_ENDPOINT=
AZURE_DOC_INTELLIGENCE_KEY=

# --- Cross-document LLM reasoning (Step 5) ---
# Azure OpenAI (Azure AI Foundry, GPT-4 Turbo) is the ONLY primary LLM path.
# Set ALL THREE (endpoint, key, deployment) to enable GPT-4 Turbo reasoning;
# otherwise Step 5 degrades to the deterministic rule-based fallback.
#   Obtain: Azure AI Foundry / Portal -> Azure OpenAI resource -> deploy a chat
#   model -> use the resource endpoint, a key, and the DEPLOYMENT name.
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2024-06-01

# --- Claude (Anthropic) for Agents 13 + 14 ---
# Agent 13 (Holistic Plausibility) and Agent 14 (Cross-Agent Adjudicator) use
# Claude Opus. Provide the key to enable them; without it both degrade to a
# neutral, non-flagging stub.
ANTHROPIC_API_KEY=
AGENT13_MODEL=claude-opus-4-6
AGENT14_MODEL=claude-opus-4-6

# --- Agent 9 backend selector ---
# "pca_autoencoder" (default, no GPU) or "patchcore" (requires anomalib + GPU,
# see requirements-optional.txt).
AGENT9_BACKEND=pca_autoencoder

# --- Hugging Face model IDs (Step 3 - Document Understanding) ---
DIT_MODEL_ID=microsoft/dit-base
LAYOUTLMV3_MODEL_ID=microsoft/layoutlmv3-base
DONUT_MODEL_ID=naver-clova-ix/donut-base

# --- Template / OOD index source (Agent 4 + Step 3) ---
# "local" uses the templates/ directory (default). Set to "azure_blob" and
# provide the connection string below to fetch authentic templates from Blob
# Storage (organised as <container>/<doc_type>/<file>) -- no code changes.
TEMPLATE_SOURCE=local
AZURE_BLOB_CONNECTION_STRING=
AZURE_BLOB_TEMPLATE_CONTAINER=authentic-templates

# --- Rendering ---
RASTER_DPI=150

# --- OCR engines ---
# PaddleOCR (2nd OCR engine, activates Agent 10 cross-OCR disagreement).
# Off by default because its weights download from a model host on first use;
# set to 1 once paddleocr + paddlepaddle are installed and the host is reachable.
ENABLE_PADDLEOCR=0

# --- Detection thresholds (override defaults from config.py) ---
OOD_THRESHOLD=1.5
AGENT2_THRESHOLD=0.4
AGENT4_SSIM_THRESHOLD=0.7
AGENT5_PHASH_THRESHOLD=10
AGENT9_THRESHOLD=0.6
AGENT9_NOVELTY_HIGH=0.75
AGENT10_THRESHOLD=0.5
AGENT11_DELTA_THRESHOLD=0.2
AGENT12_THRESHOLD=0.3
RULE1_UNCERTAINTY_THRESHOLD=0.25
RULE2_DISAGREEMENT_DELTA=0.4
RULE2_MIN_AGENTS=2

# --- Consent gate (DPDP/GDPR) ---
# Consent gate — set to 0 only in dev/dry-run environments
REQUIRE_CONSENT=1

# --- Upload limits ---
MAX_FILE_BYTES=52428800
