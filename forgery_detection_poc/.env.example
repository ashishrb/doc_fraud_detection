# Copy to .env and fill in. All keys are OPTIONAL for the POC — missing keys
# cause the corresponding agent/step to degrade gracefully (see SETUP.md).

# --- Azure Document Intelligence (Step 2 primary OCR) ---
# Obtain: Azure Portal -> create "Document Intelligence" resource -> Keys & Endpoint
AZURE_DOC_INTELLIGENCE_ENDPOINT=
AZURE_DOC_INTELLIGENCE_KEY=

# --- Cross-document LLM reasoning (Step 5) ---
# Provide ONE of the following.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# Model id: gpt-4-turbo / gpt-4o / claude-opus-4-6 etc.
CROSS_DOC_MODEL=gpt-4-turbo

# Optional VLLM extraction model id (unused unless configured).
AGENT15_MODEL=

# --- Template / OOD index source (Agent 4 + Step 3) ---
# "local" uses the templates/ directory (default). Set to "azure_blob" and
# provide the connection string below to fetch authentic templates from Blob
# Storage (organised as <container>/<doc_type>/<file>) -- no code changes.
TEMPLATE_SOURCE=local
AZURE_BLOB_CONNECTION_STRING=
AZURE_BLOB_TEMPLATE_CONTAINER=authentic-templates

# --- Rendering ---
RASTER_DPI=150

# --- OCR engines ---
# PaddleOCR (2nd OCR engine, activates Agent 10 cross-OCR disagreement).
# Off by default because its weights download from a model host on first use;
# set to 1 once paddleocr + paddlepaddle are installed and the host is reachable.
ENABLE_PADDLEOCR=0

# --- Detection thresholds (override defaults from config.py) ---
OOD_THRESHOLD=1.5
AGENT2_THRESHOLD=0.4
AGENT4_SSIM_THRESHOLD=0.7
AGENT5_PHASH_THRESHOLD=10
AGENT9_THRESHOLD=0.6
AGENT9_NOVELTY_HIGH=0.75
AGENT10_THRESHOLD=0.5
AGENT11_DELTA_THRESHOLD=0.2
RULE1_UNCERTAINTY_THRESHOLD=0.25
RULE2_DISAGREEMENT_DELTA=0.4
RULE2_MIN_AGENTS=2

# --- Upload limits ---
MAX_FILE_BYTES=52428800
